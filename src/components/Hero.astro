---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const u = (path: string) => `${base}${path}`;
const hasScreenshot = true;
---
<section class="hero">
  <div class="hero-inner">
    <div class="hero-text">
      <div class="hero-eyebrow">Self-hosted &nbsp;·&nbsp; Open source &nbsp;·&nbsp; Docker Compose</div>

      <h1 class="hero-headline">
        keep your directories<br/>in line.
      </h1>

      <p class="hero-sub">
        tidemarq runs entirely on your own hardware. No cloud account, no remote agents,
        no proprietary folder structure — just a clean web UI and complete control of your files.
      </p>

      <div class="hero-actions">
        <a href={u('/docs/installation')} class="btn btn-primary">
          Get started
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4"/>
          </svg>
        </a>
        <a href="https://github.com/puckrin/tidemarq" target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
          <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
              0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13
              -.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66
              .07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15
              -.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27
              .68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12
              .51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48
              0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          View on GitHub
        </a>
      </div>

      <div class="hero-cmd">
        <span class="hero-cmd-prompt">$</span>
        docker compose up
      </div>
    </div>

    <div class="hero-screenshot-wrap">
      <div class="hero-browser">
        <div class="browser-dots">
          <span></span><span></span><span></span>
        </div>
        <div class="browser-bar">https://localhost:8717</div>
      </div>
      {hasScreenshot ? (
        <img
          class="hero-screenshot"
          src={u('/screenshots/dashboard.png')}
          alt="tidemarq dashboard showing sync job status, recent activity, and statistics"
          width="1020"
          height="574"
        />
      ) : (
        <div class="hero-screenshot-placeholder">
          Dashboard screenshot — run <code>npm run screenshots</code> to capture
        </div>
      )}
    </div>
  </div>
</section>
