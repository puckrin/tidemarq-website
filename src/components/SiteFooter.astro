---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const u = (path: string) => `${base}${path}`;
---
<footer class="site-footer">
  <div class="container">
    <a href={u('/')} class="footer-logo">
      <div class="footer-logo-mark">tm</div>
      <span class="footer-logo-name">tidemarq</span>
    </a>

    <ul class="footer-links">
      <li><a href={u('/docs')}>Documentation</a></li>
      <li><a href="https://github.com/puckrin/tidemarq" target="_blank" rel="noopener noreferrer">GitHub</a></li>
      <li><a href="https://github.com/puckrin/tidemarq/issues" target="_blank" rel="noopener noreferrer">Issues</a></li>
      <li><a href="https://github.com/puckrin/tidemarq/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">License</a></li>
    </ul>

    <span class="footer-copy">MIT License</span>
  </div>
</footer>
