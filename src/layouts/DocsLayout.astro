---
import BaseLayout from './BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title?: string;
  description?: string;
  currentPage?: string;
  breadcrumb?: string;
}

const {
  title,
  description,
  currentPage = '',
  breadcrumb = '',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const u = (path: string) => `${base}${path}`;

const navGroups = [
  {
    label: 'Getting Started',
    items: [
      { label: 'Overview',      href: u('/docs') },
      { label: 'Installation',  href: u('/docs/installation') },
      { label: 'Configuration', href: u('/docs/configuration') },
    ],
  },
  {
    label: 'Features',
    items: [
      { label: 'Sync Jobs',     href: u('/docs/jobs') },
      { label: 'Mounts',        href: u('/docs/mounts') },
      { label: 'Conflicts',     href: u('/docs/conflicts') },
      { label: 'Version History', href: u('/docs/versioning') },
      { label: 'Audit Log',     href: u('/docs/audit') },
    ],
  },
];
---
<BaseLayout title={title ? `${title} — tidemarq docs` : undefined} description={description}>
  <SiteNav activePage="docs" />

  <div class="docs-wrapper">
    <aside class="docs-sidebar">
      {navGroups.map(group => (
        <div class="sidebar-section">
          <div class="sidebar-section-label">{group.label}</div>
          <ul class="sidebar-nav">
            {group.items.map(item => (
              <li>
                <a
                  href={item.href}
                  class={currentPage === item.label ? 'active' : ''}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </aside>

    <main class="docs-main">
      {breadcrumb && (
        <div class="docs-breadcrumb">
          <a href={u('/docs')}>Docs</a>
          <span>›</span>
          <span>{breadcrumb}</span>
        </div>
      )}
      <article class="docs-content">
        <slot />
      </article>
    </main>
  </div>

  <SiteFooter />
</BaseLayout>
